      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Blau = Hot Path / Benutzeraktion · Grün = fachlicher Write/Callback über FastAPI · Magenta gestrichelt = n8n-Orchestrierung · Dunkelgrau =\nDatenbankpersistenz · Orange gestrichelt = Fallback/Kontext",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Blau = Hot Path / Benutzeraktion · Grün = fachlicher Write/Callback über FastAPI · Magenta gestrichelt = n8n-Orchestrierung · Dunkelgrau =\nDatenbankpersistenz · Orange gestrichelt = Fallback/Kontext",
      "lineHeight": 1.2,
      "fontWeight": "400"
    },
