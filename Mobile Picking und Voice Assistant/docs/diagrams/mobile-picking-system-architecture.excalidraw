      "roundness": null,
      "seed": 66594,
      "version": 1,
      "versionNonce": 179058,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "FastAPI erstellt den Alert zuerst in Odoo. Bei n8n-Erfolg\nwird `pending` gesetzt. Bei Dispatch-Fehler greift lokaler\nBackend-Fallback. n8n-Writebacks laufen nur über interne\nFastAPI-Callbacks.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FastAPI erstellt den Alert zuerst in Odoo. Bei n8n-Erfolg\nwird `pending` gesetzt. Bei Dispatch-Fehler greift lokaler\nBackend-Fallback. n8n-Writebacks laufen nur über interne\nFastAPI-Callbacks.",
      "lineHeight": 1.2,
      "fontWeight": "400"
    },
