      "link": null,
      "locked": false,
      "text": "1 · Picking-Bestätigung",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1 · Picking-Bestätigung",
      "lineHeight": 1.2,
      "fontWeight": "700"
    },
    {
      "id": "txt_0060",
      "type": "text",
      "x": 58,
      "y": 920,
      "width": 464,
      "height": 66.56,
      "angle": 0,
      "strokeColor": "#52606d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
