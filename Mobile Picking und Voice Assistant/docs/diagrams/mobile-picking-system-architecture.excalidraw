      "frameId": null,
      "roundness": null,
      "seed": 60540,
      "version": 1,
      "versionNonce": 162780,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "PWA → FastAPI `/confirm-line` → Claim/Idempotency-Prüfung\n→ Odoo-Write. Danach feuert FastAPI `pick-confirmed`\nasynchron an n8n; fachlich bleibt das Picking auch bei\nn8n-Degradation gültig.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PWA → FastAPI `/confirm-line` → Claim/Idempotency-Prüfung\n→ Odoo-Write. Danach feuert FastAPI `pick-confirmed`\nasynchron an n8n; fachlich bleibt das Picking auch bei\nn8n-Degradation gültig.",
      "lineHeight": 1.2,
      "fontWeight": "400"
    },
