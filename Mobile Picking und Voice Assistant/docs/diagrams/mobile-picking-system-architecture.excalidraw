      "roundness": null,
      "seed": 63567,
      "version": 1,
      "versionNonce": 170919,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Normaler Voice-Pfad: PWA → FastAPI → Whisper → lokale\nIntent-Logik → PWA. Ausnahmeassistenz: FastAPI reichert\nOdoo/Obsidian-Kontext an und fragt n8n synchron mit\nlokalem Fallback.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Normaler Voice-Pfad: PWA → FastAPI → Whisper → lokale\nIntent-Logik → PWA. Ausnahmeassistenz: FastAPI reichert\nOdoo/Obsidian-Kontext an und fragt n8n synchron mit\nlokalem Fallback.",
      "lineHeight": 1.2,
      "fontWeight": "400"
    },
